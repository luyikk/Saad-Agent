# ==========================================
# Saad-Agent 环境变量配置
# ==========================================
# 复制此文件为 .env 并填入你的配置值

# ---------- DeepSeek API 配置 ----------
# 【必填】API 密钥
# 获取: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# 模型名称（默认: deepseek-v4-flash）
# DEEPSEEK_MODEL=deepseek-v4-flash

# ---------- 对话行为 ----------
# 最大对话轮次，超过后自动退出（默认: 100）
# SAAD_MAX_TURNS=100

# 最大 Token 数，控制单次响应的长度上限（默认: 384000）
# SAAD_MAX_TOKENS=384000

# 保留的历史消息数，防止上下文过长（默认: 20）
# SAAD_MAX_HISTORY=20

# ---------- 回答风格 ----------
# 努力程度 / 详细度
# 可选值:
#   concise / low       - 精炼模式，直接给结论
#   normal / medium     - 默认，平衡详细度
#   elaborate / high    - 详细模式，展示思考过程
# 默认: normal
# SAAD_EFFORT=normal
